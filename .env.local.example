# TheChemSolver — Supabase credentials
# Copy this file to .env.local and fill in your values from:
# Supabase Dashboard → Project Settings → API

NEXT_PUBLIC_THECHEMSOLVER_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_THECHEMSOLVER_SUPABASE_ANON_KEY=your_anon_key_here

# Service role key — used ONLY in server-side scripts (step4_v2.py) and the
# Razorpay webhook route, never exposed to the browser
THECHEMSOLVER_SUPABASE_SERVICE_KEY=your_service_role_key_here

# Razorpay — $15/year ad-free purchase. See docs/RAZORPAY_SETUP.md for how to
# get each of these, and for enabling International Payments (USD cards).
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_key_secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret
RAZORPAY_CURRENCY=USD
RAZORPAY_AMOUNT_USD=15

# Used to build post-payment redirect URLs
NEXT_PUBLIC_SITE_URL=https://www.thechemsolver.com
